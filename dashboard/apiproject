    if not extracted_raw_text:
        st.error("OCR execution did not parse any decipherable string characters.")
        st.stop()
        
    with st.expander("Inspected Raw Parsed Text"):
        st.text_area("Engine View", value=extracted_raw_text, height=100, disabled=True)

    # LLM Query Generation & Parsing
    with st.spinner("Consulting MechGPT Solver Core..."):
        structured_prompt = (
            f"You are ANSYS expert. Error: {extracted_raw_text}. "
            f"Explain cause in 2 lines + give 3 exact click-by-click fix steps for ANSYS Workbench. "
            f"No theory."
        )
        
        try:
            api_payload = openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {
                        "role": "system", 
                        "content": "You are a rigid engineering utility engine. You do not talk conversationally. Provide text answers formatted strictly to the requested constraints."
                    },
                    {"role": "user", "content": structured_prompt}
                ],
                temperature=0.0
            )
            llm_response = api_payload.choices[0].message.content
            
            # Final Output Render UI Stage
            st.markdown("### 🛠️ Structural/Mechanical Remediation Execution Protocol")
            st.info(llm_response)
            
            doc_url = get_documentation_link(extracted_raw_text)
            st.markdown(f"🔗 **Reference Material Link:** [Access ANSYS Customer Portal Guide]({doc_url})")
            
        except Exception as error_instance:
            st.error(f"OpenAI Core Engine communication breakdown: {error_instance}")
