    if not api_key:
        st.error("🔑 Please supply your OpenAI API Key via the sidebar to activate the solver engine.")
        st.stop()
        
    # Safely initialize the client now that we guarantee api_key exists
    openai_client = openai.OpenAI(api_key=api_key)

    # Load and display image asset
    original_img = Image.open(uploaded_file)
