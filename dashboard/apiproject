def preprocess_image(image: Image.Image) -> np.ndarray:
    """Converts PIL Image to a high-contrast grayscale CV2 array for optimal OCR."""
    img_array = np.array(image.convert("RGB"))
    gray = cv2.cvtColor(img_array, cv2.COLOR_RGB2GRAY)
    # Thresholding to isolate text cleanly from mechanical simulation background noise
    processed_img = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY | cv2.THRESH_OTSU)[1]
    return processed_img

def extract_text_from_image(processed_img: np.ndarray) -> str:
    """Runs Tesseract OCR over the processed image array."""
    try:
        text = pytesseract.image_to_string(processed_img)
        return text.strip()
    except Exception as e:
        st.error("🚨 Tesseract Binary not detected or misconfigured on host machine.")
        st.info("Ensure `tesseract` package is installed on your OS system paths.")
        return ""

def get_documentation_link(error_text: str) -> str:
    """Scans text against our mapping to return relevant documentation."""
    lowered = error_text.lower()
    for keyword, link in DOCS_DB.items():
        if keyword in lowered:
            return link
    return "https://ansyshelp.ansys.com/" # Default fallback

